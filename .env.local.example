# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kakao Share
NEXT_PUBLIC_KAKAO_API_KEY=your-kakao-js-key

# Google login is configured in Supabase Auth > Providers > Google.

# Toss Payments
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxx
TOSS_SECRET_KEY=test_sk_xxxx

# OpenAI
OPENAI_API_KEY=sk-xxxx
# 구독(sub) 모드용 별도 키. 없으면 OPENAI_API_KEY 로 폴백.
OPENAI_API_KEY_SUB=sk-xxxx
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2

# Async generation worker
GENERATION_WORKER_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_ASYNC_GENERATION_ENABLED=false

# Distributed rate limiting (optional; local memory fallback is used when omitted)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin
ADMIN_EMAILS=dkpark55@gmail.com
